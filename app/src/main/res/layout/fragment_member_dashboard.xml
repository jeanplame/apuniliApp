<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:orientation="vertical"
    tools:context=".ui.membership.MemberDashboardFragment">

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?android:attr/colorBackground"
        android:fitsSystemWindows="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Section d'accueil personnalisée -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tv_welcome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bienvenue, Jean !"
                android:textAppearance="?attr/textAppearanceHeadlineMedium"
                android:textColor="@android:color/black"
                android:gravity="center"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:fontFamily="sans-serif-medium" />

            <!-- Hero Section - Member Info Card modernisée -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_hero_profile"
                style="@style/DashboardHeroCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                app:cardElevation="8dp"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:padding="28dp">

                    <!-- Photo centrée -->
                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/iv_profile_photo"
                        android:layout_width="96dp"
                        android:layout_height="96dp"
                        android:layout_gravity="center"
                        android:contentDescription="Photo de profil"
                        android:src="@drawable/ic_person"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                        android:backgroundTint="@android:color/darker_gray"
                        android:elevation="8dp" />

                    <!-- Nom et email -->
                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tv_member_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@android:color/black"
                        android:textStyle="bold"
                        android:textSize="22sp"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:fontFamily="sans-serif-medium"
                        tools:text="Jean Dupont" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tv_member_email"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@android:color/black"
                        android:textSize="15sp"
                        android:gravity="center"
                        android:layout_marginTop="2dp"
                        tools:text="jean.dupont@example.com" />

                    <!-- Date d'adhésion -->
                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tv_member_since"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@android:color/darker_gray"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:layout_marginTop="2dp"
                        tools:text="Membre depuis 15/03/2026" />

                    <!-- Badge Statut modernisé -->
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="12dp"
                        android:text="ACTIF"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        app:chipBackgroundColor="@android:color/holo_green_dark"
                        app:chipIcon="@android:drawable/checkbox_on_background"
                        app:chipIconTint="@android:color/white"
                        app:iconStartPadding="8dp"
                        app:iconEndPadding="8dp"
                        app:iconPadding="8dp"
                        app:closeIconEnabled="false" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section Avantages modernisée -->
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Vos avantages exclusifs"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="@android:color/black"
                android:gravity="start"
                android:layout_marginStart="32dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:fontFamily="sans-serif-medium" />

            <GridLayout
                android:id="@+id/grid_benefits"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="3"
                android:layout_marginHorizontal="24dp"
                android:layout_marginBottom="24dp"
                android:useDefaultMargins="true"
                android:elevation="2dp" />

            <!-- Section Certificat modernisée -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginBottom="24dp"
                app:cardElevation="6dp"
                app:cardCornerRadius="18dp"
                app:cardBackgroundColor="@android:color/darker_gray">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical"
                    android:baselineAligned="false">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_members"
                        app:tint="@android:color/black"
                        android:contentDescription="Certificat" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="20dp">

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Certificat officiel d'adhésion"
                            android:textAppearance="?attr/textAppearanceTitleSmall"
                            android:textStyle="bold"
                            android:textColor="@android:color/black" />

                    </LinearLayout>

                    <Button
                        android:id="@+id/btn_download_certificate"

                        android:layout_width="65dp"
                        android:layout_height="wrap_content"
                        android:textColor="@android:color/black"
                        android:textSize="15sp"
                        app:icon="@android:drawable/stat_sys_download" />


                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Loading State -->
            <ProgressBar
                android:id="@+id/progress_loading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone"
                tools:visibility="visible" />

            <!-- Error State -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tv_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="16dp"
                android:textColor="@android:color/holo_red_dark"
                android:visibility="gone"
                tools:text="Erreur lors du chargement"
                tools:visibility="visible" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
