<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Gradients pour les sections du dashboard -->
    <item name="bg_dashboard_hero" type="drawable">
        <shape xmlns:android="http://schemas.android.com/apk/res/android">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="?attr/colorPrimaryContainer"
                android:endColor="?attr/colorSurfaceVariant" />
        </shape>
    </item>

    <!-- Fond pour les cartes des bénéfices -->
    <item name="bg_benefit_card" type="drawable">
        <shape xmlns:android="http://schemas.android.com/apk/res/android">
            <solid android:color="?attr/colorSurface" />
            <stroke
                android:width="1dp"
                android:color="?attr/colorOutline" />
            <corners android:radius="12dp" />
        </shape>
    </item>

    <!-- Ripple pour actions -->
    <item name="bg_ripple_light" type="drawable">
        <ripple
            xmlns:android="http://schemas.android.com/apk/res/android"
            android:color="?attr/colorOnSurfaceVariant">
            <item android:drawable="?attr/colorSurface" />
        </ripple>
    </item>
</resources>

