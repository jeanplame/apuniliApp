<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Styles Material 3 pour le Dashboard -->

    <!-- Hero Card Style -->
    <style name="DashboardHeroCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardElevation">2dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">?attr/colorPrimary</item>
        <item name="contentPaddingBottom">0dp</item>
        <item name="contentPaddingLeft">0dp</item>
        <item name="contentPaddingRight">0dp</item>
        <item name="contentPaddingTop">0dp</item>
    </style>

    <!-- Section Card Style -->
    <style name="DashboardSectionCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardElevation">1dp</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="contentPadding">16dp</item>
    </style>

    <!-- Benefit Card Style -->
    <style name="DashboardBenefitCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardElevation">0dp</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">?attr/colorOutline</item>
    </style>

    <!-- Section Title Style -->
    <style name="DashboardSectionTitle">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textAppearance">?attr/textAppearanceHeadlineSmall</item>
    </style>

    <!-- Profile Info Title -->
    <style name="DashboardProfileTitle">
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textAppearance">?attr/textAppearanceTitleMedium</item>
    </style>

    <!-- Benefit Title -->
    <style name="DashboardBenefitTitle">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAppearance">?attr/textAppearanceBodyLarge</item>
    </style>

    <!-- Button Style for Quick Access -->
    <style name="DashboardActionButton" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_height">48dp</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <!-- Status Chip Style -->
    <style name="DashboardStatusChip" parent="Widget.MaterialComponents.Chip.Action">
        <item name="android:textSize">11sp</item>
        <item name="android:layout_gravity">center_vertical</item>
        <item name="chipIconSize">16dp</item>
    </style>
</resources>



