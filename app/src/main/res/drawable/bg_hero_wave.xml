<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#0D47A1"
                android:centerColor="#1565C0"
                android:endColor="#1976D2"
                android:type="linear" />
        </shape>
    </item>
    <!-- Decorative overlay glow -->
    <item
        android:top="100dp"
        android:left="-40dp"
        android:right="200dp"
        android:bottom="-60dp">
        <shape android:shape="oval">
            <solid android:color="#151E88E5" />
        </shape>
    </item>
    <item
        android:top="-30dp"
        android:left="180dp"
        android:right="-60dp"
        android:bottom="80dp">
        <shape android:shape="oval">
            <solid android:color="#1090CAF9" />
        </shape>
    </item>
</layer-list>

